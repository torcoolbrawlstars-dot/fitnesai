# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor generated web assets (regenerated by `cap sync` in CI)
/ios/App/App/public
/android/app/src/main/assets/public

# iOS build artifacts
/ios/App/build
/ios/App/DerivedData
/ios/App/Pods
/ios/App/App.xcodeproj/xcuserdata
/ios/App/App.xcodeproj/project.xcworkspace/xcuserdata
/ios/App/App.xcworkspace/xcuserdata
DerivedData/
*.xcuserstate

# Android build artifacts
/android/.gradle
/android/build
/android/app/build
/android/local.properties
/android/.idea
